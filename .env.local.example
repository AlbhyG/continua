# Supabase - Get these from https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Resend - Get this from https://resend.com/api-keys
RESEND_API_KEY=re_your-api-key-here

# Email Configuration
RESEND_FROM_EMAIL=reply@yourdomain.com
RESEND_REPLY_TO_EMAIL=person@yourdomain.com
NOTIFY_EMAIL=person@yourdomain.com

# Contact PDF delivery
# Optional: set this to send one same private Supabase Storage PDF for every role.
# If unset, the app uses agents.pdf, publishers.pdf, and therapists.pdf by role.
CONTACT_PDF_STORAGE_PATH=
PDF_OWNER_PASSWORD=replace-with-a-strong-owner-password

# Site URL - Used for email verification links
# Local: http://localhost:3000
# Production: Set to your deployed domain (e.g., https://continua.com)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Notes:
# - NEXT_PUBLIC_ vars are exposed to the browser (safe - anon key is designed for client use with RLS)
# - RESEND_API_KEY is server-only (never prefix with NEXT_PUBLIC_)
# - RESEND_FROM_EMAIL must match a verified domain in Resend dashboard
# - RESEND_REPLY_TO_EMAIL receives replies to transactional email
# - CONTACT_PDF_STORAGE_PATH is a private file in the Supabase Storage "books" bucket
# - For local dev: copy this file to .env.local and fill in real values
# - For Vercel: add these in Project Settings > Environment Variables
